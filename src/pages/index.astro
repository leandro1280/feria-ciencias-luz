---
import fs from 'node:fs';
import path from 'node:path';

const fotosDir = path.join(process.cwd(), 'public', 'fotos');
let fotos = [];
try {
  fotos = fs.readdirSync(fotosDir)
    .filter(file => file.match(/\.(jpe?g|png)$/i))
    .map(file => {
      const base = import.meta.env.BASE_URL;
      const separator = base.endsWith('/') ? '' : '/';
      return `${base}${separator}fotos/${file}`;
    });
} catch (e) {
  console.error("No se pudo leer la carpeta de fotos:", e);
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>La Luz - Feria de Ciencias</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Exo:wght@400;700&family=Roboto+Mono:wght@400;500&display=swap');

    :root {
      --primary: #FF4D4D;
      --secondary: #4D94FF;
      --cta: #00E676;
      --bg: #0a0a0c;
      --text: #F5F5F7;
    }

    body, html {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background-color: var(--bg);
      color: var(--text);
      font-family: 'Roboto Mono', monospace;
      overflow: hidden;
    }

    h1, h2, h3 {
      font-family: 'Exo', sans-serif;
    }

    #slideshow-container {
      position: relative;
      width: 100%;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      perspective: 1000px;
    }

    .slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-size: contain;
      background-position: center;
      background-repeat: no-repeat;
      opacity: 0;
      transform: scale(1.1);
      filter: blur(10px);
    }

    .glass-overlay {
      position: absolute;
      bottom: 10%;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 2.5rem 5rem;
      border-radius: 24px;
      text-align: center;
      z-index: 10;
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .glass-overlay h1 {
      margin: 0;
      font-size: 3.5rem;
      text-transform: uppercase;
      letter-spacing: 4px;
      color: #fff;
      text-shadow: 0 0 15px var(--secondary), 0 0 30px var(--cta);
    }
    
    .glass-overlay p {
      margin-top: 15px;
      font-size: 1.4rem;
      letter-spacing: 1px;
    }

    #start-btn {
      margin-top: 30px;
      padding: 16px 40px;
      font-size: 1.2rem;
      font-family: 'Exo', sans-serif;
      font-weight: bold;
      background: linear-gradient(135deg, var(--secondary), var(--primary));
      color: white;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      box-shadow: 0 4px 25px rgba(77, 148, 255, 0.5);
      transition: all 0.3s ease;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    #start-btn:hover {
      transform: translateY(-3px) scale(1.05);
      box-shadow: 0 8px 30px rgba(255, 77, 77, 0.6);
    }

    .controls {
      position: absolute;
      top: 20px;
      right: 20px;
      z-index: 20;
      display: flex;
      gap: 15px;
    }
    
    .icon-btn {
      background: rgba(0,0,0,0.5);
      border: 1px solid rgba(255,255,255,0.2);
      color: white;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      backdrop-filter: blur(10px);
      transition: background 0.3s, transform 0.2s;
    }

    .icon-btn:hover {
      background: rgba(255,255,255,0.3);
      transform: scale(1.1);
    }
    
    .hidden {
      opacity: 0;
      pointer-events: none;
      transform: translate(-50%, 20px);
    }

    /* Refraction effect overlay */
    .refraction-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, rgba(77,148,255,0.05) 0%, rgba(0,230,118,0.05) 50%, rgba(255,77,77,0.05) 100%);
      mix-blend-mode: screen;
      pointer-events: none;
      z-index: 5;
    }
  </style>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.2/anime.min.js" is:inline></script>
</head>
<body>

  <div id="slideshow-container">
    {fotos.length === 0 && <p style="z-index: 100; position: absolute;">No se encontraron fotos en public/fotos/</p>}
    {fotos.map((foto, index) => (
      <div class="slide" style={`background-image: url('${foto}')`} data-index={index}></div>
    ))}
    
    <div class="refraction-overlay"></div>

    <div class="glass-overlay" id="intro-card">
      <h1>La Luz</h1>
      <p>Propagación, Reflexión y Refracción</p>
      <p style="font-size: 1rem; color: #ccc; margin-top: 10px;">Escuela N° 35 Leandro N. Alem - 6° Año Div A</p>
      <button id="start-btn">Iniciar Presentación</button>
    </div>

    <div class="controls">
      <button class="icon-btn" id="fullscreen-btn" title="Pantalla Completa">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>
      </button>
    </div>
  </div>

  <script is:inline>
    let wakeLock = null;
    const startBtn = document.getElementById('start-btn');
    const introCard = document.getElementById('intro-card');
    const fullscreenBtn = document.getElementById('fullscreen-btn');
    const slides = document.querySelectorAll('.slide');
    
    let currentIndex = 0;
    let isPlaying = false;
    let slideInterval;

    // Wake Lock API
    async function requestWakeLock() {
      try {
        if ('wakeLock' in navigator) {
          wakeLock = await navigator.wakeLock.request('screen');
          console.log('Screen Wake Lock actived');
          
          wakeLock.addEventListener('release', () => {
            console.log('Screen Wake Lock released');
          });
        }
      } catch (err) {
        console.error(`${err.name}, ${err.message}`);
      }
    }

    // Handle visibility change for wake lock
    document.addEventListener('visibilitychange', async () => {
      if (wakeLock !== null && document.visibilityState === 'visible' && isPlaying) {
        await requestWakeLock();
      }
    });

    // Fullscreen toggle
    fullscreenBtn.addEventListener('click', () => {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(err => {
          console.log(`Error attempting to enable fullscreen: ${err.message}`);
        });
      } else {
        document.exitFullscreen();
      }
    });

    // Slideshow Logic
    function shuffleArray(array) {
      const arr = Array.from(array);
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    const shuffledSlides = shuffleArray(slides);

    function nextSlide() {
      const currentSlide = shuffledSlides[currentIndex];
      
      currentIndex = (currentIndex + 1) % shuffledSlides.length;
      const nextSlideEl = shuffledSlides[currentIndex];

      // Animating out current slide
      anime({
        targets: currentSlide,
        opacity: [1, 0],
        scale: [1, 1.05],
        filter: ['blur(0px)', 'blur(20px)'],
        duration: 3000,
        easing: 'easeInOutSine'
      });

      // Animating in next slide
      anime({
        targets: nextSlideEl,
        opacity: [0, 1],
        scale: [1.05, 1],
        filter: ['blur(20px)', 'blur(0px)'],
        duration: 3000,
        easing: 'easeInOutSine'
      });
    }

    startBtn.addEventListener('click', async () => {
      if (slides.length === 0) {
        alert("No se encontraron fotos. Asegúrate de que estén en public/fotos/");
        return;
      }
      
      introCard.classList.add('hidden');
      isPlaying = true;
      
      await requestWakeLock();
      
      // Mostrar la primera diapo
      const firstSlide = shuffledSlides[0];
      anime({
        targets: firstSlide,
        opacity: [0, 1],
        scale: [1.1, 1],
        filter: ['blur(20px)', 'blur(0px)'],
        duration: 2500,
        easing: 'easeOutSine'
      });

      // Pasar cada 6 segundos
      slideInterval = setInterval(nextSlide, 6000);
    });
  </script>
</body>
</html>
